# Môi trường chạy ứng dụng (development/production/test)
NODE_ENV=development

# Cổng khởi chạy Server Backend
PORT=3000

# Đường dẫn kết nối CSDL PostgreSQL (sử dụng trong Sequelize)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/styx_pc_store

# Khóa bí mật ký mã hóa JWT và thời gian hết hạn
JWT_SECRET=styx_haven_vn_very_secret_key_123456
JWT_EXPIRES_IN=1h

# URL Frontend (dùng cho CORS)
FRONTEND_URL=http://localhost:5500

# API Mô phỏng tích hợp (Mock URL)
PAYMENT_MOCK_URL=http://localhost:3000/api/payment/mock
SHIPPING_MOCK_URL=http://localhost:3000/api/shipping/mock

# Chế độ thông báo (mock/console/email/sms)
NOTIFICATION_MODE=console

# Mức độ log hệ thống (debug/info/warn/error)
LOG_LEVEL=info
